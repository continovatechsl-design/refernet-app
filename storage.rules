rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Mirror src/firebase.js -> ADMIN_EMAILS and firestore.rules -> adminEmails().
    function adminEmails() {
      return [
        'continovatech.sl@gmail.com'
      ];
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email in adminEmails();
    }

    // requests/{requestId}/quotation-*.pdf and requests/{requestId}/invoice-*.pdf
    // Cross-service rule: looks up the matching Firestore `requests/{requestId}`
    // doc so the referrer/submitter (not just admin) can view their own files.
    match /requests/{requestId}/{fileName} {
      function requestDoc() {
        return firestore.get(/databases/(default)/documents/requests/$(requestId)).data;
      }

      allow read: if isAdmin()
        || (isSignedIn() && requestDoc().submittedByUid == request.auth.uid)
        || (isSignedIn() && requestDoc().referrerUid == request.auth.uid);

      // Only admin uploads quotation/invoice PDFs; cap size, PDF only.
      allow write: if isAdmin()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';

      allow delete: if isAdmin();
    }
  }
}
