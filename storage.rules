rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Mirror src/firebase.js -> ADMIN_EMAILS. Firestore rules can't read
    // your .env file, so keep this list in sync manually.
    function adminEmails() {
      return [
        'continovatech.sl@gmail.com'
      ];
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email in adminEmails();
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // users/{uid} — profile + points balance
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      // Owner can edit their own display fields & fcmToken, but NOT points.
      // Admin can edit anything (needed to increment points on completion).
      allow update: if isAdmin()
        || (isOwner(uid) && request.resource.data.points == resource.data.points);
      allow delete: if false;
    }

    // referralCodes/{code} -> { uid } — write-once mapping, used to
    // guarantee unique codes and resolve "who does this code belong to".
    match /referralCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // requests/{id} — job requests submitted by referrers/customers
    match /requests/{id} {
      allow read: if isAdmin()
        || resource.data.submittedByUid == request.auth.uid
        || resource.data.referrerUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.submittedByUid == request.auth.uid;
      // Only admin can change status/quotation/points after creation.
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
